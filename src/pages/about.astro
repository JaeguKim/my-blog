---
import AboutHeroImage from "../assets/blog-placeholder-about.jpg";
import Layout from "../layouts/BlogPost.astro";
---

<Layout
  title="About Me"
  description="Backend Software Engineer at KRAFTON"
  pubDate={new Date("December 13 2025")}
  heroImage={AboutHeroImage}
>
  <style>
    .profile-section {
      display: flex;
      align-items: center;
      gap: 2em;
      margin-bottom: 2.5em;
    }
    .profile-image {
      width: 180px;
      height: 180px;
      border-radius: 50%;
      object-fit: cover;
      flex-shrink: 0;
    }
    .profile-intro h2 {
      margin-top: 0;
      font-size: 1.8em;
      margin-bottom: 0.5em;
    }
    .profile-intro p {
      margin: 0;
      font-size: 1.1em;
      color: rgb(var(--gray));
    }
    @media (max-width: 720px) {
      .profile-section {
        flex-direction: column;
        text-align: center;
      }
      .profile-image {
        width: 150px;
        height: 150px;
      }
    }
  </style>

  <div class="profile-section">
    <img src="/profile.jpg" alt="Jacob Kim" class="profile-image" />
    <div class="profile-intro">
      <h2>Jacob Kim</h2>
      <p>Backend Software Engineer at KRAFTON</p>
    </div>
  </div>

  <p>
    I'm Jacob Kim, a Backend Software Engineer at KRAFTON working on OVERDARE -
    a UGC platform for creating and sharing interactive games.
  </p>

  <p>
    I build scalable backend systems using Go, TypeScript, and Python. My work
    focuses on API development, distributed systems, and improving developer
    productivity.
  </p>

  <p>
    <strong>Tech Stack:</strong> Go, TypeScript, Python, Kubernetes, gRPC, PostgreSQL,
    Redis, DynamoDB
  </p>

  <p>
    Previously interned at NAVER. Graduated from Kyungpook National University
    with a degree in Computer Science.
  </p>

  <p>
    Reach me at <a href="mailto:rlaworn1993@gmail.com">rlaworn1993@gmail.com</a> or
    check out my <a href="https://github.com/JaeguKim" target="_blank">GitHub</a
    >.
  </p>
</Layout>
