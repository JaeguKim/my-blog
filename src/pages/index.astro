---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Hi, I'm Jacob</h1>
			<p>
				Backend Software Engineer at KRAFTON, building scalable systems for OVERDARE - a UGC platform where users create and share interactive games.
			</p>
			<p>
				I work with Go, TypeScript, and Python to build distributed systems, APIs, and developer tools. This blog is where I share my thoughts on software engineering, backend development, and technology.
			</p>
			<p>
				Check out my <a href="/blog">blog posts</a> or learn more <a href="/about">about me</a>.
			</p>
		</main>
		<Footer />
	</body>
</html>
